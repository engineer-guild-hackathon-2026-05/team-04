# Supabase クライアント（フロント・サーバー両方から使う公開キー）
# Supabase Dashboard > Project Settings > API Keys の Publishable key（sb_publishable_...）を設定
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here

# サーバー専用（絶対にクライアントに露出させない / NEXT_PUBLIC_ プレフィックス禁止）
# DB-backed guest login の Route Handler でのみ使用
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter（サーバー専用。NEXT_PUBLIC_ プレフィックス禁止）
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# guest login のCookie署名専用。SUPABASE_SERVICE_ROLE_KEYとは分離した長いランダム値を必ず設定します。
# DEMO_SESSION_SECRET=replace-with-a-long-random-secret

# ログイン画面の「デモで体験する」ボタンは常時表示され、DB-backed guest sessionを作成します。
# 旧DEMO_MODEでは制御しません。SUPABASE_SERVICE_ROLE_KEYまたはDEMO_SESSION_SECRETがない場合は/auth/demoが503を返します。
