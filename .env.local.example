# Supabase クライアント（フロント・サーバー両方から使う公開キー）
# `supabase status` の API URL と anon key、または Supabase Dashboard > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# サーバー専用（絶対にクライアントに露出させない / NEXT_PUBLIC_ プレフィックス禁止）
# DB-backed デモログインと、管理用途の Route Handler でのみ使用
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# デモログインのCookie署名用。未設定時はSUPABASE_SERVICE_ROLE_KEYを署名にも使います。
# DEMO_SESSION_SECRET=replace-with-a-long-random-secret

# 有効化すると、ログイン画面の「デモで体験する」ボタンからDB-backed demo sessionを作成します。
# NEXT_PUBLIC_DEMO_MODE はボタン表示、DEMO_MODE は /auth/demo route の有効化に使います。
NEXT_PUBLIC_DEMO_MODE=false
DEMO_MODE=false
