# Supabase クライアント（フロント・サーバー両方から使う公開キー）
# `supabase status` の API URL と anon key、または Supabase Dashboard > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# サーバー専用（絶対にクライアントに露出させない / NEXT_PUBLIC_ プレフィックス禁止）
# 管理用途でのみ使用。通常の認証フローでは不要
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# AI レシピ生成は Next.js API route からのみ OpenRouter を呼び出します。
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# OpenRouter（サーバー専用。NEXT_PUBLIC_ プレフィックス禁止）
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# OpenRouter（サーバー専用。NEXT_PUBLIC_ プレフィックス禁止）
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# OpenRouter（サーバー専用。NEXT_PUBLIC_ プレフィックス禁止）
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# デモモードを有効にすると、任意のメールアドレスとパスワードでログインできます。
DEMO_MODE=false
